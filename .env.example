# PostgreSQL connection for message persistence
# Remove/comment out to use the bundled postgres container
PG_HOST=postgres
PG_PORT=5432
PG_DB=mqtt
PG_USER=mqtt
PG_PASS=change_me_postgres_password

# Dashboard
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASS=change_me_dashboard_password

# Built-in MQTT users created by init/setup.sh
MQTT_COAP_SERVER_USER=coap-server
MQTT_COAP_SERVER_PASS=change_me_coap_password
MQTT_NRF_USER=nrf
MQTT_NRF_PASS=change_me_nrf_password
MQTT_SENSOR_DEVICE_USER=sensor-device
MQTT_SENSOR_DEVICE_PASS=change_me_sensor_password
MQTT_VESSEL_USER=vessel
MQTT_VESSEL_PASS=change_me_vessel_password
